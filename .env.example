OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o

# Backend
PORT=3001
FRONTEND_URL=http://localhost:4200

# PostgreSQL
# For local dev (npm run dev / npm run dev:backend):
#   Postgres runs in podman compose (docker-compose.dev.yml) with port 5432 mapped to host.
#   Use @localhost:5432.
# For full Docker/Podman compose (docker-compose.yml):
#   Backend connects via the internal network; use @postgres:5432.
DATABASE_URL=postgresql://hermeneutica:hermeneutica_pass@localhost:5432/hermeneutica

# Path to the data directory containing bibles/ subfolder.
# For local dev (npm run dev / npm run dev:backend, or cd backend && npm run start:dev):
#   The backend process runs with cwd=./backend, so set DATA_DIR=../data.
# For Docker/Podman compose (docker-compose.yml):
#   The backend cwd inside the container is /app, so set DATA_DIR=./data (the default).
DATA_DIR=../data

# Optional: path to a local directory containing patristic source files
# (HTML or TXT, e.g. downloaded from New Advent – Church Fathers).
# The repository does NOT include any patristic texts; place your legally
# obtained files here and then run:  cd backend && npm run index:patristic
# PATRISTIC_DATA_DIR=/path/to/your/patristic-data
