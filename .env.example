OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o
PORT=3001
FRONTEND_URL=http://localhost:4200
DATABASE_URL=postgresql://hermeneutica:hermeneutica_pass@localhost:5432/hermeneutica
# Path to the data directory containing bibles/ subfolder.
# Defaults to <cwd>/data (correct for Docker where cwd=/app).
# For manual dev (cd backend && npm run start:dev), set to ../data.
DATA_DIR=./data
# Optional: path to a local directory containing patristic source files
# (HTML or TXT, e.g. downloaded from New Advent – Church Fathers).
# The repository does NOT include any patristic texts; place your legally
# obtained files here and then run:  cd backend && npm run index:patristic
# PATRISTIC_DATA_DIR=/path/to/your/patristic-data
